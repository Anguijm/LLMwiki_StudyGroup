# ============================================================================
# LLMwiki_StudyGroup v0 — environment variables
# ============================================================================
# Only v0 keys live here. v1+ keys (AssemblyAI, Discord, web-push VAPID) are
# added in the PR that wires up the feature, alongside its rate-limit and
# auth controls. CI grep gate enforces this.

# --- Supabase (auth, Postgres+pgvector, Storage, Realtime) ------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVICE ROLE KEY — server only. Never import from client components.
# Guarded by the `server-only` npm package in /packages/db/server.ts.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# --- Anthropic (Haiku 4.5 for simplify + future Opus for exam gen) ----------
ANTHROPIC_API_KEY=

# --- Voyage (voyage-3 embeddings) -------------------------------------------
VOYAGE_API_KEY=

# --- PDF parsing -------------------------------------------------------------
# Pick ONE parser. Set PDF_PARSER and populate the matching key below; leave
# the other blank. resolvePdfParser() in packages/lib/ai validates that the
# selected parser's key is present (providing the other does NOT satisfy).
# LlamaParse has the lightest signup (~2 min at llamaindex.ai) and is the
# recommended default for first-time deploys.
PDF_PARSER=llamaparse
REDUCTO_API_KEY=
LLAMAPARSE_API_KEY=

# --- Upstash (two-tier rate limits: event count + token budget) -------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Inngest (async job runner) ---------------------------------------------
# In production these are auto-populated by the Inngest Vercel marketplace
# integration (install at vercel.com/integrations/inngest) — no CLI needed.
# For local dev via `inngest-cli dev`, generate keys at: Inngest dashboard
# → Settings → Keys.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- App base URL (used in emails / redirect callbacks) ---------------------
APP_BASE_URL=http://localhost:3000
