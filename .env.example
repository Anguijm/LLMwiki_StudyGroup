# ============================================================================
# LLMwiki_StudyGroup v0 — environment variables
# ============================================================================
# Only v0 keys live here. v1+ keys (AssemblyAI, Discord, web-push VAPID) are
# added in the PR that wires up the feature, alongside its rate-limit and
# auth controls. CI grep gate enforces this.

# --- Supabase (auth, Postgres+pgvector, Storage, Realtime) ------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVICE ROLE KEY — server only. Never import from client components.
# Guarded by the `server-only` npm package in /packages/db/server.ts.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# --- Anthropic (Haiku 4.5 for simplify + future Opus for exam gen) ----------
ANTHROPIC_API_KEY=

# --- Voyage (voyage-3 embeddings) -------------------------------------------
VOYAGE_API_KEY=

# --- PDF parsing -------------------------------------------------------------
# Default is reducto; llamaparse is the fallback. Set one, the other, or both.
PDF_PARSER=reducto
REDUCTO_API_KEY=
LLAMAPARSE_API_KEY=

# --- Upstash (two-tier rate limits: event count + token budget) -------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Inngest (async job runner) ---------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- App base URL (used in emails / redirect callbacks) ---------------------
APP_BASE_URL=http://localhost:3000
